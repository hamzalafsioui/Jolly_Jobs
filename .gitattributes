# =================================================================
# .gitattributes — enforce correct line endings per file type
# Critical: shell scripts MUST be LF inside Linux containers
# =================================================================

# Default: normalize all text files to LF in the repo
* text=auto eol=lf

# Shell scripts — always LF (will break on Alpine if CRLF)
*.sh        text eol=lf
Makefile    text eol=lf

# Windows batch files — always CRLF
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# Docker / config files — LF
Dockerfile          text eol=lf
*.conf              text eol=lf
docker-compose*.yml text eol=lf
.env*               text eol=lf

# Binary files — no line-ending conversion
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.pdf   binary
*.zip   binary
